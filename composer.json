{
    "name": "poli-page/sdk",
    "description": "Poli Page SDK for PHP — render PDFs from HTML templates via the Poli Page API",
    "type": "library",
    "license": "MIT",
    "keywords": ["pdf", "html", "template", "rendering", "poli-page"],
    "homepage": "https://github.com/poli-page/sdk-php",
    "support": {
        "issues": "https://github.com/poli-page/sdk-php/issues",
        "source": "https://github.com/poli-page/sdk-php",
        "docs": "https://docs.poli.page"
    },
    "require": {
        "php": "^8.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^3.0",
        "php-http/discovery": "^1.20"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "guzzlehttp/guzzle": "^7.8",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^6.4 || ^7.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client (most common choice in PHP — ~80% of projects)",
        "symfony/http-client": "PSR-18 HTTP client (Symfony-native alternative)",
        "nyholm/psr7": "Lightweight PSR-7 + PSR-17 implementations",
        "monolog/monolog": "PSR-3 logger (most common). Any PSR-3 LoggerInterface works."
    },
    "autoload": {
        "psr-4": {
            "PoliPage\\": "src/"
        },
        "files": [
            "src/render_to_file.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PoliPage\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "format": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "audit": "composer audit",
        "ci": ["@lint", "@analyse", "@audit", "@test"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
