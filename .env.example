# Copy to .env at the repo root and edit. `.env` is gitignored.
#
# The examples/demo.php script + the integration test suite both read
# from this file at the repo root. process.env (POLI_PAGE_API_KEY in
# your shell) always wins over the file when both are set.

# Required for the demo + integration tests. Test keys start with pp_test_;
# they never bill, never send real documents, and have generous rate
# limits. Get one at https://app.poli.page → your org → API keys.
POLI_PAGE_API_KEY=pp_test_replace_me

# Optional: point at the develop API instead of prod. Comment out (or
# set to https://api.poli.page) for production-flavoured testing.
# POLI_PAGE_BASE_URL=https://api-develop.poli.page

# Optional: pin the template the integration suite renders against.
# Defaults to getting-started/welcome/1.0.0 which is auto-provisioned
# in every Poli Page org.
# POLI_PAGE_TEST_PROJECT=getting-started
# POLI_PAGE_TEST_TEMPLATE=welcome
# POLI_PAGE_TEST_VERSION=1.0.0
